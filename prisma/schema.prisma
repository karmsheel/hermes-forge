// Prisma schema for Hermes Forge - Phase 1: Business Discovery
// Source of truth: Structured Business Knowledge Graph

generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  businesses Business[]
}

model Business {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String
  industry    String?
  description String?
  teamSize    Int?
  website     String?
  goals       String?
  constraints String?
  backfillCompletedAt DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  processes Process[]
  memories  Memory[]
  events    BusinessEvent[]
}

model BusinessEvent {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  userId     String?

  type       String
  entityType String?
  entityId   String?
  entityName String?

  summary  String
  metadata String?

  source    String   @default("live")
  createdAt DateTime @default(now())

  @@index([businessId, createdAt(sort: Desc)])
}

model Process {
  id                 String   @id @default(cuid())
  businessId         String
  business           Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  name               String
  description        String
  department         String   // Sales | Marketing | Operations | Finance | Support | HR | Custom
  trigger            String?
  inputs             String?
  outputs            String?
  manualSteps        String?

  // Automation scoring (0-100)
  automationScore    Int      @default(0)
  estimatedTimeSaved Int?     // hours/week
  repetition         Int?     // 1-10
  businessValue      Int?     // 1-10
  complexity         Int?     // 1-10

  status             String   @default("mapping") // mapping | reviewed | approved
  approvedAt         DateTime?
  nameStatus         String   @default("pending")    // pending | confirmed — auto-name awaiting user OK

  // Live process diagram (Mermaid source) — updated as the user chats
  diagramMermaid     String?
  diagramUpdatedAt   DateTime?

  messages           ChatMessage[]
  automation         Automation?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Automation {
  id                String   @id @default(cuid())
  processId         String   @unique
  process           Process  @relation(fields: [processId], references: [id], onDelete: Cascade)

  type              String?  // hermes_cron | n8n_workflow (set on deploy — Sprint 3)
  status            String   @default("designing") // designing | ready_to_deploy | deployed | needs_credentials | active | paused | failed
  planJson          String?
  integrationsJson  String?
  credentialMapJson String?
  externalId        String?
  externalUrl       String?
  deployedAt        DateTime?

  messages          AutomationMessage[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model AutomationMessage {
  id           String     @id @default(cuid())
  automationId String
  automation   Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)

  role         String     // user | assistant
  content      String
  createdAt    DateTime   @default(now())
}

model ChatMessage {
  id        String   @id @default(cuid())
  processId String
  process   Process  @relation(fields: [processId], references: [id], onDelete: Cascade)

  role      String   // user | assistant
  content   String
  createdAt DateTime @default(now())
}

model Memory {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  fact        String
  confidence  Float    @default(0.8)
  source      String?  // e.g. "interview-turn-3"
  lastUpdated DateTime @default(now())
}
