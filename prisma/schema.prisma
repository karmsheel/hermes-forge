// Prisma schema for Hermes Forge - Phase 1: Business Discovery
// Source of truth: Structured Business Knowledge Graph

generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  businesses Business[]
}

model Business {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String
  avatarEmoji String?
  avatarIcon  String?
  industry    String?
  description String?
  teamSize    Int?
  website     String?
  goals       String?
  constraints String?

  // Immutable business log head
  logHeadSequence  Int       @default(0)
  logInitializedAt DateTime?

  // Local Git mirror + optional remote push (4.11)
  gitRepoPath       String?
  gitInitializedAt  DateTime?
  gitHeadCommit     String?
  gitHeadSequence   Int?
  gitDirty          Boolean   @default(false)
  gitRemoteUrl      String?
  gitRemoteBranch   String?   @default("main")
  gitLastPushedAt   DateTime?
  gitLastPushError  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  processes           Process[]
  functions           BusinessFunction[]
  conversations       Conversation[]
  memories            Memory[]
  documents           BusinessDocument[]
  contentItems        ContentItem[]
  metrics             BusinessMetric[]
  events              BusinessEvent[]
  decisions           BusinessDecision[]
  decisionRequests    DecisionRequest[]
  notifications       Notification[]
  humanPersonnel      HumanPersonnel[]
  hermesAgentProfiles HermesAgentProfile[]
  agentTrainingItems  AgentTrainingItem[]
}

/// Declared org function / department on the business map (Map stage).
/// Empty functions (no workflows yet) still appear on the Functions chart.
model BusinessFunction {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  name        String
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([businessId, name])
  @@index([businessId])
}

/// Operational content inventory (Phase 5) — pieces you ship, not knowledge docs.
model ContentItem {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  title         String
  bodyMarkdown  String   @default("")
  status        String   @default("idea") // idea | draft | review | ready | shipped
  channel       String?  // linkedin | x | newsletter | blog | other
  source        String   @default("manual") // manual | hermes | import
  processId     String?
  automationId  String?
  scheduledFor  DateTime?
  shippedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId, status, updatedAt(sort: Desc)])
  @@index([businessId, createdAt(sort: Desc)])
}

/// Metric definition for Monitor stage (Phase 5).
model BusinessMetric {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  name              String
  channel           String?  // linkedin | x | newsletter | site | other
  unit              String   @default("count")
  collectionMethod  String   @default("manual") // manual | hermes_job | integration
  cadenceGoal       Float?   // e.g. posts per week target when relevant
  notes             String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  samples MetricSample[]

  @@index([businessId, name])
}

model MetricSample {
  id        String         @id @default(cuid())
  metricId  String
  metric    BusinessMetric @relation(fields: [metricId], references: [id], onDelete: Cascade)

  value     Float
  recordedAt DateTime @default(now())
  source    String    @default("manual") // manual | hermes | import
  notes     String?

  @@index([metricId, recordedAt(sort: Desc)])
}

/// Durable markdown knowledge for a business (4.18) — not process maps.
model BusinessDocument {
  id               String   @id @default(cuid())
  businessId       String
  business         Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  title            String
  kind             String   // basics | customers | market | strategy | freeform
  slug             String
  bodyMarkdown     String   @default("")
  pinnedForContext Boolean  @default(false)
  sortOrder        Int      @default(0)
  source           String   @default("manual") // seed | import | manual | hermes
  // HITL lifecycle (4.12): draft → refined → forged
  lifecycleStatus  String   @default("draft") // draft | refined | forged
  forgedAt         DateTime?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([businessId, slug])
  @@index([businessId, sortOrder])
  @@index([businessId, pinnedForContext])
  @@index([businessId, lifecycleStatus])
}

model BusinessEvent {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  userId     String?

  sequence            Int
  type                String
  entityType          String?
  entityId            String?
  entityName          String?

  summary  String
  metadata String?

  recordedAt          DateTime
  occurredAt          DateTime?
  occurredAtPrecision String    @default("unknown") // exact | approximate | unknown
  ingestion           String    @default("live")    // live | backfill | import

  payloadHash    String?
  prevPayloadHash String?
  gitCommitSha   String?

  @@unique([businessId, sequence])
  @@index([businessId, recordedAt(sort: Desc)])
}

model BusinessDecision {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  decidedByUserId String?
  title           String
  statement       String
  rationale       String?
  context         String?

  // forge | change | policy | redirect | reject
  kind                   String    @default("policy")
  status                 String    @default("active") // active | superseded | revoked
  decidedAt              DateTime?
  recordedAt             DateTime  @default(now())
  relatedEntityType      String?
  relatedEntityId        String?
  supersededByDecisionId String?
  sourceRequestId        String?
  logSequence            Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId, recordedAt(sort: Desc)])
  @@index([businessId, status])
  @@index([businessId, decidedAt(sort: Desc)])
  @@index([businessId, kind, recordedAt(sort: Desc)])
  @@index([sourceRequestId])
}

/// Pending HITL ticket: agent/forge proposes options; human resolves (4.12).
model DecisionRequest {
  id                   String   @id @default(cuid())
  businessId           String
  business             Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  title                String
  summary              String
  contextMarkdown      String   @default("")

  status               String   @default("pending") // pending | resolved | redirected | cancelled
  urgency              String   @default("normal") // normal | high

  proposerKind         String   // agent | forge | system
  hermesAgentProfileId String?
  hermesAgentProfile   HermesAgentProfile? @relation(fields: [hermesAgentProfileId], references: [id], onDelete: SetNull)
  conversationId       String?

  relatedEntityType    String? // process | document | automation | business
  relatedEntityId      String?
  relatedEntityName    String?

  /// JSON: DecisionOption[]
  optionsJson          String
  /// JSON: Record<optionId, ProposedAction | ProposedAction[]>
  proposedActionsJson  String   @default("{}")

  selectedOptionId     String?
  redirectMessage      String?
  resolvedAt           DateTime?
  resolvedByUserId     String?

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  notifications        Notification[]

  @@index([businessId, status, createdAt(sort: Desc)])
  @@index([businessId, createdAt(sort: Desc)])
  @@index([hermesAgentProfileId])
}

/// In-app notifications (user attention); forever retention (4.12).
model Notification {
  id                String   @id @default(cuid())
  businessId        String
  business          Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  userId            String

  type              String   // info | decision_pending | decision_resolved | system
  title             String
  body              String   @default("")
  decisionRequestId String?
  decisionRequest   DecisionRequest? @relation(fields: [decisionRequestId], references: [id], onDelete: SetNull)
  readAt            DateTime?

  createdAt         DateTime @default(now())

  @@index([businessId, userId, createdAt(sort: Desc)])
  @@index([businessId, userId, readAt])
  @@index([decisionRequestId])
}

// kind: process (workshop mapping) | studio (global chatbar co-pilot)
// processId is null for studio threads; businessId is always set (4.17 PR-2).
// hermesAgentProfileId scopes studio threads to a hired agent (chatbar picker).
model Conversation {
  id                   String              @id @default(cuid())
  businessId           String
  business             Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  processId            String?
  process              Process?            @relation(fields: [processId], references: [id], onDelete: Cascade)
  hermesAgentProfileId String?
  hermesAgentProfile   HermesAgentProfile? @relation(fields: [hermesAgentProfileId], references: [id], onDelete: SetNull)
  kind                 String              @default("process") // process | studio
  title                String              @default("Main")
  forkedFromId         String? // conversation this was forked from
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  messages ChatMessage[]

  @@index([businessId, kind, updatedAt(sort: Desc)])
  @@index([businessId, kind, hermesAgentProfileId, updatedAt(sort: Desc)])
  @@index([processId, createdAt(sort: Desc)])
  @@index([hermesAgentProfileId])
}

model Process {
  id                 String   @id @default(cuid())
  businessId         String
  business           Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  name               String
  description        String
  department         String   // Sales | Marketing | Operations | Finance | Support | HR | Custom
  trigger            String?
  inputs             String?
  outputs            String?
  manualSteps        String?

  // Automation scoring (0-100)
  automationScore    Int      @default(0)
  estimatedTimeSaved Int?     // hours/week
  repetition         Int?     // 1-10
  businessValue      Int?     // 1-10
  complexity         Int?     // 1-10

  // HITL lifecycle (4.12): draft → refined → forged (legacy: mapping|reviewed|approved)
  status             String   @default("draft") // draft | refined | forged
  approvedAt         DateTime? // set when forged (compat name)
  nameStatus         String   @default("pending")    // pending | confirmed — auto-name awaiting user OK

  // Live process diagram (Mermaid source) — updated as the user chats
  diagramMermaid     String?
  diagramUpdatedAt   DateTime?

  // Phase 6.1 — black-box I/O shape (siso | simo | miso | mimo); recompute on I/O / diagram change
  ioShape            String   @default("siso")

  messages           ChatMessage[]
  conversations      Conversation[]
  automation         Automation?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Automation {
  id                String   @id @default(cuid())
  processId         String   @unique
  process           Process  @relation(fields: [processId], references: [id], onDelete: Cascade)

  type              String?  // hermes_cron | n8n_workflow (set on deploy — Sprint 3)
  status            String   @default("designing") // designing | ready_to_deploy | deployed | needs_credentials | active | paused | failed
  planJson          String?
  integrationsJson  String?
  credentialMapJson String?
  externalId        String?
  externalUrl       String?
  deployedAt        DateTime?

  // Hired Hermes agent that owns this automation (4.10)
  hermesAgentProfileId String?
  hermesAgentProfile   HermesAgentProfile? @relation(fields: [hermesAgentProfileId], references: [id], onDelete: SetNull)

  /// Bearer token for POST /api/content/ingest (Hermes cron → Content inventory)
  ingestToken       String?  @unique

  messages          AutomationMessage[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([hermesAgentProfileId])
}

model AutomationMessage {
  id           String     @id @default(cuid())
  automationId String
  automation   Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)

  role         String     // user | assistant
  content      String
  createdAt    DateTime   @default(now())
}

// processId is required for process mapping messages; null for studio chatbar messages.
model ChatMessage {
  id             String         @id @default(cuid())
  processId      String?
  process        Process?       @relation(fields: [processId], references: [id], onDelete: Cascade)
  conversationId String?
  conversation   Conversation?  @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  role      String // user | assistant
  content   String
  createdAt DateTime @default(now())

  @@index([conversationId, createdAt])
}

model Memory {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  fact        String
  confidence  Float    @default(0.8)
  source      String?  // e.g. "interview-turn-3"
  lastUpdated DateTime @default(now())
}

model HumanPersonnel {
  id              String   @id @default(cuid())
  businessId      String
  business        Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  name            String
  role            String
  roleDescription String?
  isOwner         Boolean  @default(false)
  userId          String?
  iconKey         String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([businessId, isOwner])
  @@index([businessId, createdAt(sort: Desc)])
}

model HermesAgentProfile {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  profileKey  String
  displayName String
  description String?
  model       String?
  hermesHome  String
  isDefault   Boolean  @default(false)
  iconKey     String?
  isHired     Boolean  @default(false)
  hiredAt     DateTime?

  discoveredAt DateTime @default(now())
  updatedAt    DateTime @updatedAt

  conversations     Conversation[]
  trainingItems     AgentTrainingItem[]
  automations       Automation[]
  decisionRequests  DecisionRequest[]

  @@unique([businessId, profileKey])
  @@index([businessId, discoveredAt(sort: Desc)])
  @@index([businessId, isHired])
}

// Agent Academy: uploaded skills / soul profiles / training packs (library search later).
// kind: skill | soul | profile
// source: upload | library (library reserved for shared catalog)
model AgentTrainingItem {
  id                   String              @id @default(cuid())
  businessId           String
  business             Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  hermesAgentProfileId String?
  hermesAgentProfile   HermesAgentProfile? @relation(fields: [hermesAgentProfileId], references: [id], onDelete: SetNull)

  kind        String // skill | soul | profile
  name        String
  description String?
  content     String
  fileName    String?
  source      String   @default("upload") // upload | library

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId, kind, createdAt(sort: Desc)])
  @@index([hermesAgentProfileId])
}