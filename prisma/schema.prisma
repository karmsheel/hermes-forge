// Prisma schema for Hermes Forge - Phase 1: Business Discovery
// Source of truth: Structured Business Knowledge Graph

generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  businesses Business[]
}

model Business {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String
  industry    String?
  description String?
  teamSize    Int?
  website     String?
  goals       String?
  constraints String?

  // Immutable business log head
  logHeadSequence  Int       @default(0)
  logInitializedAt DateTime?

  // Local Git mirror (future sync; inert until implemented)
  gitRepoPath       String?
  gitInitializedAt  DateTime?
  gitHeadCommit     String?
  gitHeadSequence   Int?
  gitDirty          Boolean   @default(false)
  gitRemoteUrl      String?
  gitRemoteBranch   String?   @default("main")
  gitLastPushedAt   DateTime?
  gitLastPushError  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  processes           Process[]
  memories            Memory[]
  events              BusinessEvent[]
  decisions           BusinessDecision[]
  humanPersonnel      HumanPersonnel[]
  hermesAgentProfiles HermesAgentProfile[]
}

model BusinessEvent {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  userId     String?

  sequence            Int
  type                String
  entityType          String?
  entityId            String?
  entityName          String?

  summary  String
  metadata String?

  recordedAt          DateTime
  occurredAt          DateTime?
  occurredAtPrecision String    @default("unknown") // exact | approximate | unknown
  ingestion           String    @default("live")    // live | backfill | import

  payloadHash    String?
  prevPayloadHash String?
  gitCommitSha   String?

  @@unique([businessId, sequence])
  @@index([businessId, recordedAt(sort: Desc)])
}

model BusinessDecision {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  decidedByUserId String?
  title           String
  statement       String
  rationale       String?
  context         String?

  status                 String    @default("active") // active | superseded | revoked
  decidedAt              DateTime?
  recordedAt             DateTime  @default(now())
  relatedEntityType      String?
  relatedEntityId        String?
  supersededByDecisionId String?
  logSequence            Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([businessId, recordedAt(sort: Desc)])
  @@index([businessId, status])
  @@index([businessId, decidedAt(sort: Desc)])
}

model Conversation {
  id          String   @id @default(cuid())
  processId   String
  process     Process  @relation(fields: [processId], references: [id], onDelete: Cascade)
  title       String   @default("Main")
  forkedFromId String?  // conversation this was forked from
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  messages    ChatMessage[]

  @@index([processId, createdAt(sort: Desc)])
}

model Process {
  id                 String   @id @default(cuid())
  businessId         String
  business           Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  name               String
  description        String
  department         String   // Sales | Marketing | Operations | Finance | Support | HR | Custom
  trigger            String?
  inputs             String?
  outputs            String?
  manualSteps        String?

  // Automation scoring (0-100)
  automationScore    Int      @default(0)
  estimatedTimeSaved Int?     // hours/week
  repetition         Int?     // 1-10
  businessValue      Int?     // 1-10
  complexity         Int?     // 1-10

  status             String   @default("mapping") // mapping | reviewed | approved
  approvedAt         DateTime?
  nameStatus         String   @default("pending")    // pending | confirmed — auto-name awaiting user OK

  // Live process diagram (Mermaid source) — updated as the user chats
  diagramMermaid     String?
  diagramUpdatedAt   DateTime?

  messages           ChatMessage[]
  conversations      Conversation[]
  automation         Automation?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Automation {
  id                String   @id @default(cuid())
  processId         String   @unique
  process           Process  @relation(fields: [processId], references: [id], onDelete: Cascade)

  type              String?  // hermes_cron | n8n_workflow (set on deploy — Sprint 3)
  status            String   @default("designing") // designing | ready_to_deploy | deployed | needs_credentials | active | paused | failed
  planJson          String?
  integrationsJson  String?
  credentialMapJson String?
  externalId        String?
  externalUrl       String?
  deployedAt        DateTime?

  messages          AutomationMessage[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model AutomationMessage {
  id           String     @id @default(cuid())
  automationId String
  automation   Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)

  role         String     // user | assistant
  content      String
  createdAt    DateTime   @default(now())
}

model ChatMessage {
  id             String   @id @default(cuid())
  processId      String
  process        Process  @relation(fields: [processId], references: [id], onDelete: Cascade)
  conversationId String?
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  role      String   // user | assistant
  content   String
  createdAt DateTime @default(now())
}

model Memory {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  fact        String
  confidence  Float    @default(0.8)
  source      String?  // e.g. "interview-turn-3"
  lastUpdated DateTime @default(now())
}

model HumanPersonnel {
  id              String   @id @default(cuid())
  businessId      String
  business        Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  name            String
  role            String
  roleDescription String?
  isOwner         Boolean  @default(false)
  userId          String?
  iconKey         String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([businessId, isOwner])
  @@index([businessId, createdAt(sort: Desc)])
}

model HermesAgentProfile {
  id          String   @id @default(cuid())
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  profileKey  String
  displayName String
  description String?
  model       String?
  hermesHome  String
  isDefault   Boolean  @default(false)
  iconKey     String?
  isHired     Boolean  @default(false)
  hiredAt     DateTime?

  discoveredAt DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([businessId, profileKey])
  @@index([businessId, discoveredAt(sort: Desc)])
  @@index([businessId, isHired])
}